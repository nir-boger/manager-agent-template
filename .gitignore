# Log files (local-only audit trails; not source of truth)
*.log

# Runner lock files — short-lived single-instance guards.
*.lock

# Inbox-watch operational state — rewritten every 5 min by the runner; not
# source of truth. The daily activity log (reports/inbox-watch/YYYY-MM-DD.md)
# IS tracked.
reports/inbox-watch/state.json
reports/inbox-watch/pending-items.json
reports/inbox-watch/*-temp.json
reports/inbox-watch/.*.json
reports/inbox-watch/candidates-temp.json
reports/inbox-watch/items-temp.json
reports/inbox-watch/ready-temp.json
reports/inbox-watch/roster-temp.json
# Runtime scan/roster/match snapshots (regenerated every tick; not source of truth)
reports/inbox-watch/candidates.json
reports/inbox-watch/matched-items.json
reports/inbox-watch/roster.json
reports/inbox-watch/unread.json
reports/inbox-watch/scan-*.json

# WhatsApp skill — never commit any of these:
#   - the live Chromium profile (contains WhatsApp Web session/cookies)
#   - the allowlist (contact / group names are personal data)
#   - daily action logs (may contain message snippets)
#   - node_modules under the skill folder (Playwright is heavy)
.playwright-profiles/
.copilot/skills/whatsapp/allowlist.txt
.copilot/skills/whatsapp/node_modules/
reports/whatsapp/

# Pilates skill — never commit any of these:
#   - config.json (Wellbe credentials + JWT/refresh tokens + box/membership IDs)
#   - state.json (booking attempt history)
#   - daily action logs
#   - the local Python virtualenv if one is created in-skill
# (Phase 4 of the templatize-Nirvana refactor moved the skill to examples/personal/.
#  Keeping the OLD paths too in case the forwarder dir ever picks up a config.json.)
examples/personal/pilates/config.json
examples/personal/pilates/state.json
examples/personal/pilates/.deps-installed
examples/personal/pilates/.venv/
examples/personal/pilates/__pycache__/
.copilot/skills/pilates/config.json
.copilot/skills/pilates/state.json
.copilot/skills/pilates/.deps-installed
.copilot/skills/pilates/.venv/
.copilot/skills/pilates/__pycache__/
reports/pilates/

# Team personas skill — HR-sensitive fields removed (Level, Last promotion, Birthday, Hired)
# Personas files retain working-style, role, and contact info needed for inbox-watch
.copilot/skills/team-personas/daily-summary-state.txt
.copilot/skills/team-personas/*.log

# Historical per-direct 1:1 prep files from the retired one-on-one-prep skill —
# contain persona quotes, email subject snippets, ICM context, coaching prompts.
# Skill removed 2026-05-13; folder retained for past artifacts. NEVER commit.
# Also covers the new one-on-one-agenda skill's per-person agenda files
# (reports/one-on-ones/<slug>.md) - they hold meeting talking points that
# reference internal projects and people. Local-only by design.
reports/one-on-ones/

# one-on-one-agenda runner state (preview HTML + per-occurrence idempotency
# stamps). Regenerated on every tick. Never commit.
.copilot/skills/one-on-one-agenda/state/

# PR-review-queue skill— sweep snapshots contain ADO PR titles and authors;
# historical archive — pr-review-queue skill was removed 2026-05-28
# but the existing queue files / logs are kept locally as a read-only archive.
reports/pr-review-queue/
reports/logs/pr-review-queue-*.log

# DRI-weekly-pulse skill — runtime cache (raw email bodies, week snapshots,
# rendered HTML). Local-only; tests use test-fixtures/ under the skill folder.
reports/dri-pulse/
.copilot/skills/dri-weekly-pulse/state/

# Personal-todos skill — daily rendered HTML + per-day snapshot files are
# local-only operational artifacts. The source of truth (todos.md) IS tracked.
.copilot/skills/personal-todos/state/snapshot.json
.copilot/skills/personal-todos/state/last-sent.txt
.copilot/skills/personal-todos/state/last-suggest.json
.copilot/skills/personal-todos/__pycache__/
reports/personal-todos/daily-*.html

# Connect-buddy skill — defense-in-depth.
# The actual connect data lives OUTSIDE this repo at
# %USERPROFILE%\.copilot\connect-buddy\ (HR-grade sensitive — `.gitignore` is
# not a privacy boundary, hence the off-tree path). These rules below exist
# only in case some future bug ever drops content under the skill folder.
.copilot/skills/connect-buddy/connects/
.copilot/skills/connect-buddy/manifest.json
reports/connect-buddy/

# Local scratch — not meaningful state, never push.
tmp/
reports/agent-todos/current-batch.json

# Transient input docs (planning spreadsheets, exports, etc.)
reports/inputs/

# Migration freeze flag — local-only kill switch used during refactors. When
# present, side-effect helpers (Send-RunnerSummaryEmail, etc.) skip COM calls
# and return cleanly. Activated either via this file or via
# $env:NIRVANA_MIGRATION_MODE. Never commit.
config/migration-mode.txt

# Stray scratch JSON files from ad-hoc ADO/work-item dumps. Never commit.
temp-items.json
temp-*.json
reports/semester-plan/

reports/one-shots/

# Runtime log/work dir — regenerated on every tick; never source of truth.
reports/logs/

# Persona hot/cold cache
#   Cold cache: raw Cowork JSON drops, kept forever locally but contain
#     verbatim Teams chat + email bodies — never commit.
#   Hot cache state: JSON sidecars for ## Areas / Ledger / Collaborators
#     counters. Derived; can always be rebuilt with run-personas-rebuild.ps1.
reports/personas-archive/
.copilot/skills/team-personas/people-state/

# team-agenda runner state (preview HTML + per-occurrence idempotency stamps).
# Regenerated on every tick. Never commit.
.copilot/skills/team-agenda/state/

# risk-watch runner state (per-week idempotency stamp). Runtime-only.
.copilot/skills/risk-watch/state/

# sprint-digest runner state (idempotency, per-iteration baseline, last snapshot,
# preview HTML). Regenerated from ADO every run. Never commit.
.copilot/skills/sprint-digest/state/

# ado-item-tracker skill — runtime state (diff baseline, per-day digest idempotency,
# preview HTML) + the board-facing live cache. The tracked SET
# (reports/ado-tracker/tracked.json) IS tracked; cache.json is regenerated from ADO.
.copilot/skills/ado-item-tracker/state/
reports/ado-tracker/cache.json

# team-brief skill (DM-TeamBriefDaily / DM-TeamWeeklyHighlights) — runtime state +
# rendered output that embed paraphrased M365 (Teams + email) content via WorkIQ.
#   state/: enrichment.json (WorkIQ-sourced per-person Teams/email/weekly prose) +
#     daily-sent.json / weekly-sent.json idempotency keys. Sensitive + runtime.
#   reports/team-brief/: rendered HTML briefs that embed the same content.
# Never commit either.
.copilot/skills/team-brief/state/
reports/team-brief/

# pr-review-request runner state — posted.json (per-PR dedup / idempotency),
# review-stats.json (rolling p50 baseline samples), baseline.txt (eligibility
# anchor). Rewritten every 5-min tick; NOT source of truth. Must stay untracked
# so a git reset/checkout can't revert the dedup store and re-announce active PRs.
.copilot/skills/pr-review-request/state/

# Python bytecode caches (any skill).
.copilot/skills/**/__pycache__/

# Daily-capture skill (DM-DailyCapture, 18:00 IST) — runtime staging + state +
# local handoff folder consumed by the two importers on this same machine.
#   staging/<date>/: copilot-drafted DailySummary + per-report persona files that
#     carry verbatim/paraphrased M365 (Teams + email) content — NEVER commit.
#   published/{daily-summary,personas/<date>}/: local handoff drop (replaces the
#     old OneDrive round-trip) that run-daily-summary-import.ps1 /
#     run-personas-import.ps1 poll every 10 min — same sensitive content.
#   state/<date>.json: per-phase/per-person idempotency markers. Derived runtime.
reports/daily-capture/

# Generated demo / promo decks (binary, easy to regenerate).
reports/meet-nirvana.pptx

# Nirvana-site skill — generated single-file HTML explorer. Rebuilt nightly by
# DM-NirvanaSiteBuild; ~2 MB. Source of truth lives in
# .copilot/skills/nirvana-site/{build.py,template.html}.
reports/site/

# Inbox-watch transient roster cache (Outlook GAL snapshot used between ticks
# to avoid re-resolving every contact). Regenerated on demand.
reports/inbox-watch/.roster-cache.xml
